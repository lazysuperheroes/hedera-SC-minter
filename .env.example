# ============================================
# Hedera SC Minter Suite - Environment Config
# ============================================

# Hedera operator credentials (ED25519)
ACCOUNT_ID=
PRIVATE_KEY=

# Network: TEST (testnet) or MAIN (mainnet)
ENVIRONMENT=TEST

# ============================================
# MinterContract / SoulboundMinter
# ============================================
CONTRACT_NAME=MinterContract
EVENT_NAME=MinterContractMessage

# ============================================
# $LAZY Token (optional — set costs to 0 if not using)
# ============================================

## TESTNET
LAZY_TOKEN_ID=0.0.2185
LAZY_SCT_CONTRACT_ID=0.0.2181

## MAINNET (uncomment and comment out testnet values)
#LAZY_TOKEN_ID=0.0.1311037
#LAZY_SCT_CONTRACT_ID=0.0.1311003
#LAZY_BURN_PERC=25

# ============================================
# ForeverMinter
# ============================================
FOREVER_MINTER_CONTRACT_ID=
NFT_TOKEN_ID=
PRNG_CONTRACT_ID=
LAZY_GAS_STATION_CONTRACT_ID=
LAZY_DELEGATE_REGISTRY_CONTRACT_ID=
